// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Table, Movie Table, Watchlist

model User{
  id String @id @default(uuid())
  name String
  email String @unique
  password String 

  createdAt DateTime @default(now())


  // Realtions
  movies Movie[] @relation("MovieCreator")
  watchlistItems Watchlist[]

}

// ? represents optional
// uuid generates a unique id for each

model Movie{
  id String @id @default(uuid())
  title String
  overview String?
  releaseYear Int
  genres String[] @default([])
  runtime Int?
  posterUrl String?
  createdBy String
  createdAt DateTime @default(now())

  // Realtions
  creator User @relation("MovieCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  watchlistItems Watchlist[]
}

//@default is that it holds the value that is present by default

model Watchlist{
  id String @id @default(uuid())
  userId String
  movieId String
  status WatchListStatus @default(PLANNED)
  rating Int?
  notes String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  // Realtions
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  movie Movie @relation(fields: [movieId], references: [id], onDelete: Cascade)

  @@unique([userId, movieId])
}


// Cascade If the User is deleted → all Movies created by that user are also deleted automatically.
//WatchListStatus is an enum that is a custom datatype we can create like This

enum WatchListStatus{
  PLANNED
  WATCHED
  COMPLETED
  DROPPED
}